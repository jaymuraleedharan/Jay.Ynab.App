{
  "AppSettings": {
    "Key": 1,

    "YnabApi": {
      "BaseUrl": "https://api.youneedabudget.com/v1"
    },

    "YnabCache": {
      "IsCachingEnabled": true,
      "CacheFolder": "Cache",
      "AutoExpirationInDays": 7
    },

    "BudgetCustomization": {
      "SettingsFolder": "Settings"
    },

    "ExcludeCategories": [
      "Credit Card Payments",
      "Hidden Categories",
      "Internal Master Category",
      "Uncategorized"
    ]
  },

  "UISettings": {
    "Colors": [
      {
        "Name": "LIGHTYELLOW",
        "Rgb": [ 255, 255, 204 ]
      },
      {
        "Name": "LIGHTGREEN",
        "Rgb": [ 204, 255, 204 ]
      },
      {
        "Name": "LIGHTRED",
        "Rgb": [ 255, 204, 204 ]
      },
      {
        "Name": "LIGHTBLUE",
        "Rgb": [ 204, 236, 255 ]
      }
    ]
  }
}